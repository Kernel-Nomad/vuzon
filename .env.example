# Copy this file to .env and fill in the values.
# Suggested minimum token permissions: Email Routing (account and zone) read and edit.

# --- Minimum to start (Docker Compose or npm start) ---

# Cloudflare API token
CF_API_TOKEN=

# Domain where Email Routing runs (aliases are user@DOMAIN)
DOMAIN=

# Panel credentials (required; do not leave AUTH_PASS empty or whitespace-only — startup will fail)
AUTH_USER=admin
AUTH_PASS=change_this_password

# With Docker Compose: the compose file sets PORT=8001 inside the container. In .env set only
# VUZON_PORT if you want a different port on your host (host → container mapping).
VUZON_PORT=8001

# --- Optional / advanced ---

# If set, startup does not try to resolve them from DOMAIN + token
# CF_ZONE_ID=
# CF_ACCOUNT_ID=

# Trusted proxy hops for req.ip (e.g. rate limit behind nginx). Default: 1 if NODE_ENV=production, otherwise off.
# TRUST_PROXY=1

# Without Docker (`npm start`): PORT takes precedence over VUZON_PORT for the listen port.
# PORT=8001

# Session secret. If missing, ./sessions/.session_secret is created (persistent with the Compose volume);
# if .session_secret existed at the project root, it is still read.
# SESSION_SECRET=

# Public panel URL (documentation reference; the app does not read this today)
# BASE_URL=https://vuzon.example.com

# production enables production mode (e.g. cookies)
# NODE_ENV=production

# Tuning for requests to api.cloudflare.com
# CF_API_TIMEOUT_MS=
# CF_API_MAX_GET_RETRIES=

# Failed login attempts per IP (sliding window).
# LOGIN_RATE_LIMIT_MAX=30
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_MAX=0 disables the limit (useful in tests or controlled environments).
# LOGIN_RATE_LIMIT_MAX_BUCKETS=10000
