# Copia este archivo a .env y rellena los valores.
# Permisos mínimos sugeridos del token: Email Routing (cuenta y zona) lectura y edición.

# --- Mínimo para arrancar (Docker Compose o npm start) ---

# Token de API de Cloudflare
CF_API_TOKEN=

# Dominio donde opera Email Routing (se usan alias usuario@DOMAIN)
DOMAIN=

# Credenciales del panel (obligatorias; no dejes AUTH_PASS vacío ni solo espacios — el arranque fallará)
AUTH_USER=admin
AUTH_PASS=cambia_esta_contraseña

# Con Docker Compose: el fichero compose fija PORT=8001 dentro del contenedor. En .env define solo
# VUZON_PORT si quieres otro puerto en tu máquina (mapeo host → contenedor).
VUZON_PORT=8001

# --- Opcional / avanzado ---

# Si están definidos, el arranque no intenta detectarlos con DOMAIN + token
# CF_ZONE_ID=
# CF_ACCOUNT_ID=

# Saltos de proxy de confianza para req.ip (p. ej. rate limit tras nginx). Por defecto: 1 si NODE_ENV=production, si no desactivado.
# TRUST_PROXY=1

# Sin Docker (`npm start`): PORT tiene prioridad sobre VUZON_PORT para el puerto de escucha.
# PORT=8001

# Secreto de sesión. Si falta, se crea ./sessions/.session_secret (persistente con el volumen de Compose);
# si existía .session_secret en la raíz del proyecto, se sigue leyendo.
# SESSION_SECRET=

# URL pública del panel (referencia en documentación; la app no la lee hoy)
# BASE_URL=https://vuzon.ejemplo.com

# production activa modo producción (p. ej. cookies)
# NODE_ENV=production

# Afinado de peticiones a api.cloudflare.com
# CF_API_TIMEOUT_MS=
# CF_API_MAX_GET_RETRIES=

# Límite de intentos fallidos de login por IP (ventana deslizante).
# LOGIN_RATE_LIMIT_MAX=30
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_MAX=0 desactiva el límite (útil en tests o entornos controlados).
# LOGIN_RATE_LIMIT_MAX_BUCKETS=10000
