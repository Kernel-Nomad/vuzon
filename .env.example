# Copia este archivo a .env y rellena los valores.
# Permisos mínimos sugeridos del token: Email Routing (cuenta y zona) lectura y edición.

# Token de API de Cloudflare
CF_API_TOKEN=

# Dominio donde opera Email Routing (se usan alias usuario@DOMAIN)
DOMAIN=

# Opcional: si están definidos, el arranque no intenta detectarlos con DOMAIN + token
# CF_ZONE_ID=
# CF_ACCOUNT_ID=

# Credenciales del panel (obligatorias para iniciar sesión)
AUTH_USER=admin
AUTH_PASS=

# Puerto HTTP (por defecto 8001). PORT tiene prioridad sobre VUZON_PORT si ambos existen.
PORT=8001
# VUZON_PORT=8001

# Opcional: secreto de sesión; si falta, se genera/usará .session_secret en el proyecto
# SESSION_SECRET=

# Opcional: URL pública del panel (referencia en documentación; la app no la lee hoy)
# BASE_URL=https://vuzon.ejemplo.com

# Opcional: production activa modo producción (p. ej. cookies)
# NODE_ENV=production

# Opcional: afinado de peticiones a api.cloudflare.com
# CF_API_TIMEOUT_MS=
# CF_API_MAX_GET_RETRIES=
