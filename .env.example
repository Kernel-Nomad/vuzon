# 1) Required:
DOMAIN=example.com
AUTH_USER=admin
AUTH_PASS=change-this-password
CF_API_TOKEN=api-example-token

# 2) Recommended: set SESSION_SECRET to a stable random value if you want to avoid session resets on restart.
# SESSION_SECRET=

# 3) Optional: set both CF_ZONE_ID and CF_ACCOUNT_ID if you want to avoid autodetection from DOMAIN.
# CF_ZONE_ID=
# CF_ACCOUNT_ID=

# 4) Optional: set VUZON_PORT to change the port the app listens on.
# VUZON_PORT=8001

# 5) Optional: set TRUST_PROXY to 1 if you want to trust X-Forwarded-* headers.
# TRUST_PROXY=1